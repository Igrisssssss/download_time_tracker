APP_NAME="CareVance"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=timetrackpro
DB_USERNAME=postgres
DB_PASSWORD=your_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
QUEUE_AFTER_COMMIT=false

CACHE_STORE=database
# CACHE_PREFIX=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_PATTERNS=^https?:\/\/(localhost|127\.0\.0\.1)(:\d+)?$
CORS_SUPPORTS_CREDENTIALS=false
CORS_MAX_AGE=3600

API_TOKEN_TTL_MINUTES=10080
SCREENSHOT_URL_TTL_MINUTES=5

RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_LOGIN_IP_PER_MINUTE=20
RATE_LIMIT_REGISTER_PER_MINUTE=3
RATE_LIMIT_HANDOFF_PER_MINUTE=10
RATE_LIMIT_PASSWORD_PER_MINUTE=5
RATE_LIMIT_SCREENSHOTS_PER_MINUTE=30
RATE_LIMIT_CHAT_MESSAGES_PER_MINUTE=60
RATE_LIMIT_NOTIFICATION_PUBLISH_PER_MINUTE=10
RATE_LIMIT_DESKTOP_DOWNLOAD_PER_MINUTE=10

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
DESKTOP_WINDOWS_DOWNLOAD_URL=https://github.com/Igrisssssss/download_time_tracker/releases/download/v1.0.0/CareVance-Setup-1.0.0-x64.exe
ATTENDANCE_LATE_AFTER=09:30:00
ATTENDANCE_SHIFT_SECONDS=28800

PAYROLL_MODE=mock
PAYROLL_DEFAULT_CURRENCY=INR
PAYROLL_STRIPE_DISABLE_SSL_VERIFY=false
PAYROLL_STRIPE_RETURN_URL=http://localhost:5173/payroll
PAYROLL_STRIPE_SUCCESS_URL=http://localhost:5173/payroll?payment=success
PAYROLL_STRIPE_CANCEL_URL=http://localhost:5173/payroll?payment=cancelled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Production guidance:
# APP_ENV=production
# APP_DEBUG=false
# LOG_STACK=stderr,daily
# LOG_LEVEL=info
# SESSION_SECURE_COOKIE=true
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
